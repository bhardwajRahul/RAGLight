# RAGLight API Server — Environment Variables
# Copy this file to .env and adjust the values.

# ── LLM ──────────────────────────────────────────────────────────────────────
# RAGLIGHT_LLM_MODEL=llama3
# RAGLIGHT_LLM_PROVIDER=Ollama
# RAGLIGHT_LLM_API_BASE=http://localhost:11434

# ── Embeddings ────────────────────────────────────────────────────────────────
# RAGLIGHT_EMBEDDINGS_MODEL=all-MiniLM-L6-v2
# RAGLIGHT_EMBEDDINGS_PROVIDER=HuggingFace
# RAGLIGHT_EMBEDDINGS_API_BASE=http://localhost:11434

# ── Vector Store ──────────────────────────────────────────────────────────────
# RAGLIGHT_PERSIST_DIR=./raglight_db
# RAGLIGHT_COLLECTION=default

# ── Retrieval ────────────────────────────────────────────────────────────────
# RAGLIGHT_K=5

# ── Optional: remote Chroma (leave unset for local PersistentClient) ──────────
# RAGLIGHT_CHROMA_HOST=
# RAGLIGHT_CHROMA_PORT=

# ── Optional: custom system prompt ───────────────────────────────────────────
# RAGLIGHT_SYSTEM_PROMPT=You are a helpful assistant.
